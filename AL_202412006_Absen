<!DOCTYPE html>
<html lang="id">

<head>
<meta charset="UTF-8"> <!-- Menentukan encoding karakter agar mendukung huruf/emoji -->
<title>Manajemen Mahasiswa</title> <!-- Judul halaman di tab browser -->

<style>

/* ===================== ALL ===================== */
body {
    margin: 0; /* Menghapus margin default browser */
    font-family: Arial; /* Mengatur jenis font utama */
    height: 100vh; /* Tinggi body penuh 1 layar */
    display: flex; /* Mengaktifkan flexbox */
    justify-content: center; /* Posisi horizontal di tengah */
    align-items: center; /* Posisi vertikal di tengah */

    background: url('https://koranusantara.com/wp-content/uploads/2026/01/f21704a5-ad49-488e-9e6a-2bebc62cba7a-1392x928-1.jpg') no-repeat center; /* Background gambar */
    background-size: cover; /* Supaya gambar memenuhi layar */
}

body::before {
    content: ""; /* Wajib untuk pseudo-element */
    position: absolute; /* Menutupi seluruh layar */
    width: 100%; /* Lebar penuh */
    height: 100%; /* Tinggi penuh */
    background: rgba(0,0,0,0.4); /* Layer hitam transparan */
    z-index: 0; /* Diletakkan di belakang */
}

.card {
    position: relative; /* Supaya berada di atas overlay */
    z-index: 1; /* Lebih tinggi dari background */
    background: rgba(255,255,255,0.40); /* Background transparan */
    padding: 25px; /* Jarak dalam */
    border-radius: 15px; /* Sudut melengkung */
    width: 750px; /* Lebar card */
    box-shadow: 0 10px 25px rgba(0,0,0,0.3); /* Efek bayangan */
}

h2 {
    color: #ffffff; /* Warna teks putih */
}

/* ===================== CLARA ===================== */
.form-group {
    display: flex; /* Membuat isi sejajar */
    gap: 10px;
    margin-bottom: 10px;
}

input, select {
    flex: 1;
    padding: 10px;
    border-radius: 8px;
    border: 1px solid #ccc;
}

.button-group {
    display: flex;
    gap: 10px;
}

button {
    flex: 1;
    padding: 10px;
    border-radius: 8px;
    border: none;
    cursor: pointer;
}

.save-btn {
    background: #00c853;
    color: white;
}

.reset-btn {
    background: #e80000;
    color: white;
}

.search-box {
    margin: 15px 0;
}

.search-box input {
    width: 100%;
}

table {
    width: 100%;
    border-collapse: collapse;
}

th {
    background: #0077ff;
    color: white;
    padding: 10px;
}

td {
    padding: 10px;
    text-align: center;
}

tr:nth-child(even) {
    background: #e3f2fd;
}

tr:nth-child(odd) {
    background: #bbdefb;
}

.delete-btn {
    background: red;
    color: white;
    border: none;
    padding: 5px;
    border-radius: 5px;
    cursor: pointer;
}

.badge {
    padding: 5px 10px;
    border-radius: 6px;
    color: white;
    font-size: 12px;
    font-weight: bold;
}

.pagi { background: #2196f3; }
.sore { background: #ff9800; }

</style>
</head>

<body>

<div class="card">

<h2>🎓 Manajemen Mahasiswa</h2>

<!-- ===================== CLARA ===================== -->
<form id="formMahasiswa">
    <div class="form-group">
        <input type="text" id="nim" placeholder="NIM" required>
        <input type="text" id="nama" placeholder="Nama Lengkap" required>
    </div>

    <div class="form-group">
        <input type="email" id="email" placeholder="Email" required>
        <input type="text" id="jurusan" placeholder="Jurusan" required>
    </div>

    <div class="form-group">
        <input type="text" id="alamat" placeholder="Alamat">
        <select id="kelas">
            <option value="">Pilih Kelas</option>
            <option>Pagi</option>
            <option>Sore</option>
        </select>
    </div>

    <div class="button-group">
        <button type="submit" class="save-btn">✔ Simpan Data</button>
        <button type="reset" class="reset-btn">🔄 Reset Form</button>
    </div>
</form>

<div class="search-box">
    <input type="text" id="search" placeholder="🔍 Cari data mahasiswa...">
</div>

<table>
<thead>
<tr>
<th>No</th>
<th>NIM</th>
<th>Nama</th>
<th>Email</th>
<th>Jurusan</th>
<th>Alamat</th>
<th>Kelas</th>
<th>Aksi</th>
</tr>
</thead>

<tbody id="tableBody"></tbody>
</table>

</div>

<script>

/* ===================== ALL ===================== */
let data = JSON.parse(localStorage.getItem("mahasiswa")) || []; 
// Mengambil data dari localStorage dengan key "mahasiswa"
// Jika tidak ada data, maka gunakan array kosong []

/* ===================== CLARA ===================== */
formMahasiswa.addEventListener("submit", function(e){
    e.preventDefault();

    let mhs = {
        nim: nim.value,
        nama: nama.value,
        email: email.value,
        jurusan: jurusan.value,
        alamat: alamat.value,
        kelas: kelas.value
    };

    data.push(mhs);
    localStorage.setItem("mahasiswa", JSON.stringify(data));

    tampilkanData();
    this.reset();
});

/* ===================== ALL ===================== */
search.addEventListener("keyup", function(){
    tampilkanData(this.value.toLowerCase()); 
    // Setiap user mengetik di search
    // data akan difilter secara real-time
});

/* ===================== ALL ===================== */
tampilkanData(); 
// Memanggil fungsi saat pertama kali halaman dibuka
// supaya data langsung tampil tanpa harus input dulu

function tampilkanData(filter=""){
    tableBody.innerHTML = "";

    data
    .filter(d =>
        d.nama.toLowerCase().includes(filter) ||
        d.nim.toLowerCase().includes(filter)
    )
    .forEach((d,i)=>{

        let kelasClass = d.kelas.toLowerCase();

        tableBody.innerHTML += `
        <tr>
            <td>${i+1}</td>
            <td>${d.nim}</td>
            <td>${d.nama}</td>
            <td>${d.email}</td>
            <td>${d.jurusan}</td>
            <td>${d.alamat}</td>
            <td><span class="badge ${kelasClass}">${d.kelas}</span></td>
            <td><button class="delete-btn" onclick="hapusData(${i})">Hapus</button></td>
        </tr>
        `;
    });
}

function hapusData(i){
    data.splice(i,1);
    localStorage.setItem("mahasiswa", JSON.stringify(data));
    tampilkanData();
}

</script>

</body>
</html>
